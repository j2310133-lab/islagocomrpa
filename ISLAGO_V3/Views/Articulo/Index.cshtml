@*
    This is the view of Articulos   
*@
@{
    ViewData["Title"] = "Articulos";
}

@section Estilos {
    <link rel="stylesheet" href="~/css/articulo.css" asp-append-version="true" />
}

<div class="articulo-container">

    <!-- HEADER -->
    <div class="articulo-header">
        <h3>Gestión de Artículos</h3>

        <button class="btn btn-success" data-toggle="modal" data-target="#modalArticulo">
            <i class="fas fa-plus"></i> Nuevo Artículo
        </button>
    </div>

    <div class="mb-3">
        <input type="text"
               id="buscadorArticulos"
               class="form-control"
               placeholder="Buscar por nombre o descripción...">
    </div>

    <!-- GRID -->
    <div class="table-container">
        <table class="table table-hover articulo-table">
            <thead>
                <tr>
                    <th>Imagen</th>
                    <th>Producto</th>
                    <th>Descripción</th>
                    <th>Stock</th>
                    <th>Unidad</th>
                    <th>Compra</th>
                    <th>Venta General</th>
                    <th>Proveedor</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="tablaArticulos">
            </tbody>
        </table>
    </div>

</div>


<!-- ========================= -->
<!-- MODAL -->
<!-- ========================= -->

<div class="modal fade" id="modalArticulo">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5>Nuevo Artículo</h5>
                <button class="close" data-dismiss="modal">&times;</button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-6">

                        <label>Nombre</label>
                        <input id="nombre" class="form-control mb-3">

                        <label>Descripción</label>
                        <textarea id="descripcion" class="form-control mb-3"></textarea>

                        <div class="row">

                            <div class="col-md-6">
                                <label>Marca</label>
                                <input id="marca" class="form-control mb-3">
                            </div>

                            <div class="col-md-6">
                                <label>SKU</label>
                                <input id="sku" class="form-control mb-3">
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6">
                                <label>Stock</label>
                                <input id="stock" type="number" class="form-control">
                            </div>

                            <div class="col-md-6">
                                <label>Stock Mínimo</label>
                                <input id="stockMinimo" type="number" class="form-control">
                            </div>

                        </div>

                        <div class="row mt-3">

                            <div class="col-md-4">
                                <label>Precio Compra</label>
                                <input id="precioCompra" type="number" step="0.01" class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label>Venta Minorista</label>
                                <input id="precioMinorista" type="number" step="0.01" class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label>Venta Mayorista</label>
                                <input id="precioMayorista" type="number" step="0.01" class="form-control">
                            </div>

                        </div>
                        <label class="mt-3">Estado</label>
                        <select id="activo" class="form-control">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-6">

                        <!-- IMÁGENES -->
                        <label>Imágenes</label>

                        <div class="upload-box">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <p>Arrastra o selecciona imágenes</p>
                            <input id="inputImagenes" type="file" multiple accept="image/*">
                        </div>

                        <div class="preview-container" id="preview"></div>

                        <!-- CATEGORÍAS -->
                        <label class="mt-3">Categorías</label>

                        <select id="categoriaSelect" class="form-control mb-2">
                            <option value="">-- Seleccionar categoría --</option>
                        </select>

                        <label class="mt-3">Unidad de Medida</label>

                        <select id="unidadMedida" class="form-control">
                            <option value="">-- Seleccionar unidad --</option>
                        </select>

                        <label class="mt-3">Proveedor</label>

                        <select id="proveedor" class="form-control">
                            <option value="">-- Seleccionar proveedor --</option>
                        </select>

                        <div id="categoriasSeleccionadas" class="categoria-box"></div>

                    </div>

                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <button id="btnGuardar" class="btn btn-primary">Guardar</button>
            </div>

        </div>
    </div>
</div>

<!-- ===================================== -->
<!-- MODAL EDITAR ARTICULO -->
<!-- ===================================== -->

<div class="modal fade" id="modalEditarArticulo">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-edit"></i>
                    Editar Artículo
                </h5>

                <button class="close text-white" data-dismiss="modal">
                    &times;
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <input type="hidden" id="editIdArticulo">

                <div class="row">

                    <!-- ========================= -->
                    <!-- IZQUIERDA -->
                    <!-- ========================= -->

                    <div class="col-md-6">

                        <label>Nombre</label>
                        <input type="text"
                               id="editNombre"
                               class="form-control mb-3">

                        <label>Descripción</label>
                        <textarea id="editDescripcion"
                                  rows="4"
                                  class="form-control mb-3"></textarea>

                        <div class="row">

                            <div class="col-md-6">
                                <label>Marca</label>
                                <input type="text"
                                       id="editMarca"
                                       class="form-control mb-3">
                            </div>

                            <div class="col-md-6">
                                <label>SKU</label>
                                <input type="text"
                                       id="editSku"
                                       class="form-control mb-3">
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6">
                                <label>Stock</label>

                                <input type="number"
                                       id="editStock"
                                       class="form-control">
                            </div>

                            <div class="col-md-6">
                                <label>Stock Mínimo</label>

                                <input type="number"
                                       id="editStockMinimo"
                                       class="form-control">
                            </div>

                        </div>

                        <div class="row mt-3">

                            <div class="col-md-4">
                                <label>Precio Compra</label>

                                <input type="number"
                                       id="editPrecioCompra"
                                       class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label>Venta Minorista</label>

                                <input type="number"
                                       id="editPrecioMinorista"
                                       class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label>Venta Mayorista</label>

                                <input type="number"
                                       id="editPrecioMayorista"
                                       class="form-control">
                            </div>

                        </div>

                        <label>Estado</label>

                        <select id="editActivo"
                                class="form-control">

                            <option value="true">
                                Activo
                            </option>

                            <option value="false">
                                Inactivo
                            </option>

                        </select>

                        <label class="mt-3">Proveedor</label>

                        <select id="editProveedor" class="form-control">
                            <option value="">-- Seleccionar proveedor --</option>
                        </select>

                    </div>

                    <!-- ========================= -->
                    <!-- DERECHA -->
                    <!-- ========================= -->

                    <div class="col-md-6">

                        <!-- IMAGENES ACTUALES -->
                        <div class="d-flex justify-content-between align-items-center">

                            <label class="mb-0">
                                Imágenes del artículo
                            </label>

                            <small class="text-muted">
                                Selecciona imagen principal
                            </small>

                        </div>

                        <!-- GALERIA -->
                        <div id="editPreview"
                             class="preview-container-edit">
                        </div>

                        <!-- AGREGAR NUEVAS -->
                        <div class="upload-box mt-3">

                            <i class="fas fa-cloud-upload-alt"></i>

                            <p>
                                Agregar nuevas imágenes
                            </p>

                            <input id="editInputImagenes"
                                   type="file"
                                   multiple
                                   accept="image/*">
                        </div>

                        <!-- PREVIEW NUEVAS -->
                        <div id="editPreviewNuevas"
                             class="preview-container mt-3">
                        </div>

                        <!-- CATEGORIAS -->
                        <label class="mt-4">
                            Categorías
                        </label>

                        <select id="editCategoriaSelect"
                                class="form-control mb-2">

                            <option value="">
                                -- Seleccionar categoría --
                            </option>

                        </select>

                        <label class="mt-3">Unidad de Medida</label>

                        <select id="editUnidadMedida" class="form-control">
                            <option value="">-- Seleccionar unidad --</option>
                        </select>

                        <div id="editCategoriasSeleccionadas"
                             class="categoria-box">
                        </div>

                    </div>

                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-dismiss="modal">

                    Cancelar
                </button>

                <button id="btnActualizarArticulo"
                        class="btn btn-primary">

                    <i class="fas fa-save"></i>
                    Guardar Cambios
                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/articulo.js" asp-append-version="true"></script>
}