@model List<ISLAGO_V3.Entidad.Models.Compra>

@{
    ViewData["Title"] = "Compras";
}

@section Estilos {
    <link rel="stylesheet"
          href="~/css/compra.css"
          asp-append-version="true" />

    <link href="#" rel="~/css/compra" />
}

<div class="compra-container">

    <div class="compra-header">

        <h3>Gestión de Compras</h3>

        <button class="btn btn-success"
                data-toggle="modal"
                data-target="#modalCompra">

            <i class="fas fa-plus"></i>
            Nueva Compra

        </button>

    </div>

    <div class="row mb-3">

        <div class="col-md-3">
            <input type="number"
                   id="buscarId"
                   class="form-control"
                   placeholder="ID Compra">
        </div>

        <div class="col-md-5">
            <input type="text"
                   id="buscarProveedor"
                   class="form-control"
                   placeholder="Proveedor">
        </div>

        <div class="col-md-4">
            <input type="date"
                   id="buscarFecha"
                   class="form-control">
        </div>

    </div>

    <div class="table-responsive">

        <div class="table-responsive">

            <div class="tabla-compras-container">

                <table class="table table-hover compra-table">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Proveedor</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody id="tablaCompras">
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<div class="modal fade" id="modalCompra">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Nueva Compra</h5>
                <button class="close" data-dismiss="modal">
                    &times;
                </button>
            </div>

            <div class="modal-body">

                <div class="row">

                    <div class="col-md-4">

                        <label>Proveedor</label>

                        <select id="proveedor"
                                class="form-control mb-3">

                            <option value="">
                                Seleccione proveedor
                            </option>

                        </select>

                    </div>

                    <div class="col-md-8">

                        <div class="table-responsive">

                            <table class="table table-bordered">

                                <thead>
                                    <tr>
                                        <th>Artículo</th>
                                        <th>Cantidad</th>
                                        <th>Precio</th>
                                        <th>Subtotal</th>
                                        <th></th>
                                    </tr>
                                </thead>

                                <tbody id="detalleCompra">
                                </tbody>

                            </table>

                        </div>

                        <button type="button"
                                class="btn btn-primary btnAgregarArticulo">

                            Agregar Artículo

                        </button>

                        <div class="total-box">
                            Total: C$
                            <span id="totalCompra">0.00</span>
                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-dismiss="modal">

                    Cancelar

                </button>

                <button id="btnGuardarCompra"
                        class="btn btn-success">

                    Guardar Compra

                </button>

            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalDetalleCompra">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5>Detalle de Compra</h5>

                <button class="close"
                        data-dismiss="modal">

                    &times;

                </button>

            </div>

            <div class="modal-body">

                <table class="table table-bordered">

                    <thead>

                        <tr>

                            <th>Artículo</th>
                            <th>Cantidad</th>
                            <th>Precio</th>
                            <th>Subtotal</th>

                        </tr>

                    </thead>

                    <tbody id="detalleCompraModal">
                    </tbody>

                </table>

                <h4 class="text-right">

                    Total:
                    C$
                    <span id="totalDetalleCompra">
                        0.00
                    </span>

                </h4>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/Compra.js" asp-append-version="true"></script>
}