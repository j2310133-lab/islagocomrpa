<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - ISLAGO</title>

    <!-- FONTS -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- BOOTSTRAP -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />

    <!-- ICONOS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- ESTILOS GLOBALES -->
    <link rel="stylesheet" href="~/css/FLagoStyle.css" asp-append-version="true" />

    <!-- ESTILOS POR VISTA -->
    @await RenderSectionAsync("Estilos", required: false)
</head>

<body>

    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">

            <div class="brand">
                <img src="~/img/logo/logo-islago-sinfondo.png">
                <div class="brand-text">
                    <span class="title">ISLAGO</span>
                    <small>Inventario</small>
                </div>
            </div>

            <nav class="nav-menu">

                <a class="active" href="@Url.Action("Index","Dashboard")">
                    <i class="fas fa-chart-pie"></i> Dashboard
                </a>

                <!-- ADMIN -->
                <div class="menu-group">
                    <div class="menu-title">
                        <span><i class="fas fa-user-cog"></i> Administración</span>
                        <i class="fas fa-chevron-down arrow"></i>
                    </div>
                    <div class="submenu">
                        <a href="@Url.Action("Index","Usuario")">
                            <i class="fas fa-user"></i> Usuarios
                        </a>
                        <a href="@Url.Action("Index","Proveedor")">
                            <i class="fas fa-truck"></i> Proveedores
                        </a>
                    </div>
                </div>

                <!-- INVENTARIO -->
                <div class="menu-group">
                    <div class="menu-title">
                        <span><i class="fas fa-boxes"></i> Inventario</span>
                        <i class="fas fa-chevron-down arrow"></i>
                    </div>
                    <div class="submenu">
                        <a href="@Url.Action("Index","Categoria")">
                            <i class="fas fa-tags"></i> Categorías
                        </a>
                        <a href="@Url.Action("Index","Articulo")">
                            <i class="fas fa-box"></i> Productos
                        </a>
                    </div>
                </div>

                <!-- ACTIVOS -->
                <div class="menu-group">
                    <div class="menu-title">
                        <span><i class="fas fa-balance-scale"></i> Pasivos y Activos</span>
                        <i class="fas fa-chevron-down arrow"></i>
                    </div>
                    <div class="submenu">
                        <a href="#"><i class="fas fa-arrow-up"></i> Activos</a>
                        <a href="#"><i class="fas fa-arrow-down"></i> Pasivos</a>
                    </div>
                </div>

                <a href="#"><i class="fas fa-chart-line"></i> Reportes</a>

            </nav>

        </aside>

        <!-- MAIN -->
        <div class="main">

            <!-- TOPBAR -->
            <header class="topbar">
                <button id="toggleSidebar" class="btn btn-sm btn-light d-md-none">
                    <i class="fas fa-bars"></i>
                </button>

                <h5>@ViewData["Title"]</h5>

                <div class="user-box">
                    <i class="fas fa-bell"></i>
                    <div class="user">
                        <i class="fas fa-user-circle"></i>
                        <span>Admin</span>
                    </div>
                </div>
            </header>

            <!-- CONTENT -->
            <main class="content">
                @RenderBody()
            </main>

        </div>

    </div>

    <!-- JS BASE -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>

    <!-- TU JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- SCRIPTS POR VISTA -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>