@{
    Layout = null;

    ViewData["Title"] = "Error del sistema";

    var codigo = ViewBag.StatusCode ?? 404;

    string titulo = "Módulo no disponible";
    string mensaje = "Este módulo aún no ha sido construido o contiene errores pendientes por corregir.";

    if (codigo == 403)
    {
        titulo = "Acceso denegado";
        mensaje = "No tienes permisos para acceder a este recurso.";
    }

    if (codigo == 500)
    {
        titulo = "Error interno";
        mensaje = "Ocurrió un problema interno en el sistema.";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <!-- GOOGLE FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- FONT AWESOME -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- CSS GLOBAL -->
    <link rel="stylesheet"
          href="~/css/FLagoStyle.css"
          asp-append-version="true" />

    <!-- CSS ERROR -->
    <link rel="stylesheet"
          href="~/css/error.css"
          asp-append-version="true" />

</head>

<body>

    <div class="error-container">

        <div class="error-card">

            <div class="error-icon">

                <i class="fas fa-triangle-exclamation"></i>

            </div>

            <span class="error-code">
                ERROR @codigo
            </span>

            <h1>@titulo</h1>

            <p>
                @mensaje
            </p>

            <div class="error-actions">

                <a href="/" class="btn-home">

                    <i class="fas fa-house"></i>

                    Volver al inicio

                </a>

                <button class="btn-back" onclick="goBack()">

                    <i class="fas fa-arrow-left"></i>

                    Regresar

                </button>

            </div>

        </div>

    </div>

    <script src="~/js/error.js" asp-append-version="true"></script>

</body>
</html>