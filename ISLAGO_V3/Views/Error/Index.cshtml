@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Módulo en construcción</title>

    <style>
            *{
                margin:0;
                padding:0;
                box-sizing:border-box;
            }

            body{
                font-family:Arial, Helvetica, sans-serif;
                background:#0f172a;
                color:white;
                height:100vh;
                display:flex;
                justify-content:center;
                align-items:center;
                padding:20px;
            }

            .container{
                text-align:center;
                max-width:700px;
            }

            h1{
                font-size:4rem;
                margin-bottom:20px;
                color:#38bdf8;
            }

            p{
                font-size:1.2rem;
                line-height:1.8;
                opacity:0.9;
            }

            .btn{
                margin-top:30px;
                display:inline-block;
                padding:14px 30px;
                background:#38bdf8;
                color:black;
                text-decoration:none;
                border-radius:10px;
                font-weight:bold;
                transition:0.3s;
            }

            .btn:hover{
                background:white;
            }

            @@media(max-width:768px){

                h1{
                    font-size:2.5rem;
                }

                p{
                    font-size:1rem;
                }
            }

    </style>
</head>
<body>

    <div class="container">

        <h1>🚧 Módulo en construcción</h1>

        <p>
            Este módulo aún no ha sido desarrollado
            o se encuentra en mantenimiento.
        </p>

        <p>
            Estamos trabajando para habilitarlo lo antes posible.
        </p>

        <a href="/" class="btn">
            Volver al inicio
        </a>

    </div>

</body>
</html>